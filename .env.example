# ============================================================
# URL Shortener Service - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/url_shortener
# Production example:
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/url_shortener

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Production example:
# REDIS_URL=redis://user:password@redis-host:6379

# URL Settings
SHORT_ID_LENGTH=7              # Length of generated short IDs
DEFAULT_TTL_DAYS=365           # Default expiry in days (0 = never expires)
CACHE_TTL_SECONDS=3600         # Redis cache TTL (1 hour)

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100    # Max requests per window per IP
